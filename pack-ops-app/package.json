{
  "name": "pack-ops-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint:domain": "tsc --noEmit",
    "migrations:list": "find ./supabase/migrations -maxdepth 1 -type f | sort",
    "supabase:status": "supabase status",
    "supabase:link": "supabase link --project-ref bktlwcqllvxkxbeibrhl",
    "supabase:db:push": "supabase db push",
    "supabase:db:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --linked --schema public > src/data/supabase/types.ts",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/react-query": "^5.90.2",
    "dexie": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.34.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "supabase": "^2.51.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "wrangler": "^4.86.0"
  }
}
